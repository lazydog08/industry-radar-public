{
  "name": "industry-radar-kb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "report:run": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:run",
    "report:noon": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:run --type noon",
    "report:night": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:run --type night",
    "report:weekly": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:weekly",
    "report:monthly": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:monthly",
    "kb:init": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts kb:init",
    "kb:search": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts kb:search",
    "nas:daily": "bash scripts/nas-daily-update.sh",
    "serve": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/server.ts",
    "sources:test": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts sources:test",
    "export:site": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx scripts/export-site.ts"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.2.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^25.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
