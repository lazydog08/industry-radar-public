{
  "name": "industry-radar-kb",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "node --test tests/*.test.mjs",
    "test:web": "node --test tests/filter-summary.test.mjs tests/editorial-frontpage.test.mjs tests/web-static-modules.test.mjs tests/web-frontpage-shell.test.mjs",
    "report:run": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:run",
    "report:morning": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:run --type morning",
    "report:noon": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:run --type noon",
    "report:night": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:run --type night",
    "report:weekly": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:weekly",
    "report:monthly": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts report:monthly",
    "kb:init": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts kb:init",
    "kb:search": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts kb:search",
    "nas:bootstrap": "bash scripts/nas-bootstrap.sh",
    "nas:daily": "bash scripts/nas-daily-update.sh",
    "nas:schedule": "bash scripts/nas-schedule.sh",
    "nas:health": "bash scripts/nas-healthcheck.sh",
    "nas:bark": "bash scripts/nas-bark-test.sh",
    "nas:web-preview": "bash scripts/nas-web-preview.sh",
    "serve": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/server.ts",
    "sources:test": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx src/cli.ts sources:test",
    "export:site": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx scripts/export-site.ts",
    "notify:bark": "NODE_OPTIONS=--no-warnings=ExperimentalWarning tsx scripts/notify-bark.ts",
    "publish:github": "bash scripts/publish-github-pages.sh",
    "nas:qnap-install": "bash scripts/qnap-install-cron.sh"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "fast-xml-parser": "^5.2.5"
  },
  "devDependencies": {
    "@types/express": "^5.0.5",
    "@types/node": "^25.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
